{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "vite", "vitest/globals"],
    "outDir": "dist"
  },
  "include": ["src", "test", "vite.config.ts"],
  "exclude": ["test/fixtures"]
}